@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-head">
    <div class="eyebrow">Overview</div>
    <h1>School dashboard</h1>
    <p>Live analytics served by the DtoOrm School API — aggregates, joins and grouped reports.</p>
</div>

<partial name="_ApiError" model="Model.ApiError" />

<div class="grid cols-3">
    <div class="card">
        <div class="stat-label">Departments</div>
        <div class="stat">@Model.Departments.Count</div>
    </div>
    <div class="card">
        <div class="stat-label">Courses in catalog</div>
        <div class="stat">@Model.TotalCourses</div>
    </div>
    <div class="card">
        <div class="stat-label">Total enrollments</div>
        <div class="stat">@Model.TotalEnrollments</div>
    </div>
</div>

<div class="grid cols-2 section-gap">
    <div class="card">
        <div class="card-title">
            <h2>Courses by department</h2>
            <span class="badge muted">LEFT JOIN · COUNT</span>
        </div>
        @if (Model.Departments.Count == 0)
        {
            <div class="empty">No departments to show.</div>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr><th>Code</th><th>Department</th><th class="num">Courses</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Departments)
                        {
                            <tr>
                                <td><span class="badge muted">@d.Code</span></td>
                                <td>@d.Name</td>
                                <td class="num">@d.CourseCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card">
        <div class="card-title">
            <h2>Most popular courses</h2>
            <span class="badge muted">GROUP BY · HAVING</span>
        </div>
        @if (Model.PopularCourses.Count == 0)
        {
            <div class="empty">No enrollments recorded yet.</div>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr><th>Code</th><th>Title</th><th class="num">Enrollments</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.PopularCourses)
                        {
                            <tr>
                                <td><span class="badge muted">@c.Code</span></td>
                                <td>@c.Title</td>
                                <td class="num">@c.EnrollmentCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card section-gap">
    <div class="card-title">
        <h2>Offering seat utilisation</h2>
        <span class="badge muted">3× INNER JOIN · LEFT JOIN · COUNT</span>
    </div>
    @if (Model.Offerings.Count == 0)
    {
        <div class="empty">No offerings to show.</div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Term</th>
                        <th>Teacher</th>
                        <th>Room</th>
                        <th class="num">Seats</th>
                        <th>Fill</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Offerings)
                    {
                        <tr>
                            <td><span class="badge muted">@o.CourseCode</span> @o.CourseTitle</td>
                            <td>@o.TermName</td>
                            <td>@o.TeacherName</td>
                            <td>@o.Room</td>
                            <td class="num">@o.Enrolled / @o.Capacity</td>
                            <td>
                                <div class="meter @(o.IsFull ? "full" : null)" style="--pct:@(o.FillPercent)%">
                                    <span></span>
                                </div>
                            </td>
                            <td class="row-actions">
                                <a asp-page="/Offerings/Details" asp-route-id="@o.OfferingId">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
