@page "{id:int}"
@model DtoOrm.Portal.Pages.Students.ScheduleModel
@{
    ViewData["Title"] = Model.Student is null ? "Student schedule" : $"{Model.Student.FullName} - Schedule";
    var weekDays = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday" };
}

<a class="back-link" asp-page="/Students/Index">Back to students</a>

<partial name="_ApiError" model="Model.ApiError" />

@if (Model.Student is not null)
{
    <div class="page-head compact">
        <div class="eyebrow">Student schedule</div>
        <h1>@Model.Student.FullName</h1>
        <p>@Model.Student.Email</p>
    </div>

    @if (Model.WeekGrid.Blocks.Count == 0)
    {
        <div class="empty-panel">No weekday classes are linked to this student.</div>
    }
    else
    {
        <div class="week-scroll">
            <div class="week-schedule" style="--rows:@Model.WeekGrid.QuarterHourRows">
                <div class="week-corner">Time</div>
                @for (var i = 0; i < weekDays.Length; i++)
                {
                    <div class="week-day" style="grid-column:@(i + 2)">@weekDays[i]</div>
                }
                @foreach (var slot in Model.WeekGrid.TimeSlots)
                {
                    <div class="week-line" style="grid-row:@slot.RowStart;grid-column:1 / -1"></div>
                    <div class="week-time" style="grid-row:@slot.RowStart / span 4">@slot.Label</div>
                }
                @foreach (var block in Model.WeekGrid.Blocks)
                {
                    <a class="week-block @(block.HasConflict ? "conflict" : null)" style="@block.Style" asp-page="/Offerings/Details" asp-route-id="@block.Item.OfferingId">
                        <time>@block.Item.TimeRange</time>
                        <strong>@block.Item.CourseCode</strong>
                        <span>@block.Item.CourseTitle</span>
                        <small>@block.Item.Location</small>
                    </a>
                }
            </div>
        </div>
    }
}
