@page
@model DtoOrm.Portal.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Students";
}

<div class="page-head">
    <div class="eyebrow">Directory</div>
    <h1>Students</h1>
    <p>Search by last name and filter by status. Backed by a parameterized <code>WHERE LIKE</code> query.</p>
</div>

<partial name="_ApiError" model="Model.ApiError" />

<form method="get" class="toolbar">
    <div class="field">
        <label for="Search">Last name starts with</label>
        <input type="search" id="Search" name="Search" value="@Model.Search" placeholder="e.g. Han" aria-describedby="student-search-help" />
        <small id="student-search-help" class="form-help">Leave empty to show all students for the selected status.</small>
    </div>
    <div class="field">
        <label for="Status">Status</label>
        <select id="Status" name="Status">
            <option value="active" selected="@(Model.Status == "active")">Active</option>
            <option value="inactive" selected="@(Model.Status == "inactive")">Inactive</option>
            <option value="all" selected="@(Model.Status == "all")">All</option>
        </select>
    </div>
    <button class="btn" type="submit">Search</button>
    <a class="btn ghost" asp-page="/Students/Index">Reset</a>
</form>

@if (Model.Students.Count == 0)
{
    <div class="card"><div class="empty">No students match your filters.</div></div>
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Enrolled</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Students)
                {
                    <tr>
                        <td>@s.FullName</td>
                        <td>@s.Email</td>
                        <td>@s.EnrolledAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge ok">Active</span>
                            }
                            else
                            {
                                <span class="badge muted">Inactive</span>
                            }
                        </td>
                        <td class="row-actions">
                            <a asp-page="/Students/Schedule" asp-route-id="@s.Id">Schedule</a>
                            <a asp-page="/Students/Transcript" asp-route-id="@s.Id">Transcript</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
