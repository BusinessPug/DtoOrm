@page "{id:int?}"
@model DtoOrm.Portal.Pages.Students.TranscriptModel
@{
    ViewData["Title"] = Model.Student is null ? "Transcript" : $"{Model.Student.FullName} - Transcript";
}

@if (User.IsInRole("Administrator") || User.IsInRole("Teacher"))
{
    <a class="back-link" asp-page="/Students/Index">Back to students</a>
}

<partial name="_ApiError" model="Model.ApiError" />

@if (Model.Student is not null)
{
    <div class="page-head">
        <div class="eyebrow">Transcript</div>
        <h1>@Model.Student.FullName</h1>
        <p>@Model.Student.Email - enrolled @Model.Student.EnrolledAt.ToString("MMMM yyyy")</p>
    </div>

    <div class="grid cols-3">
        <div class="card">
            <div class="stat-label">Credits earned</div>
            <div class="stat">@Model.TotalCredits</div>
        </div>
        <div class="card">
            <div class="stat-label">In progress</div>
            <div class="stat">@Model.InProgressCredits</div>
        </div>
        <div class="card">
            <div class="stat-label">GPA</div>
            <div class="stat">@(Model.Gpa?.ToString("0.00") ?? "-")</div>
        </div>
    </div>

    <div class="card section-gap">
        <div class="card-title">
            <h2>Course history</h2>
            <span class="badge muted">Transcript</span>
        </div>
        @if (Model.Entries.Count == 0)
        {
            <div class="empty">This student is not enrolled in any offerings yet.</div>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Term</th>
                            <th>Course</th>
                            <th>Title</th>
                            <th>Teacher</th>
                            <th class="num">Credits</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model.Entries)
                        {
                            <tr>
                                <td>@e.TermName</td>
                                <td><span class="badge muted">@e.CourseCode</span></td>
                                <td>@e.CourseTitle</td>
                                <td>@e.TeacherName</td>
                                <td class="num">@e.Credits</td>
                                <td>
                                    @if (e.IsGraded)
                                    {
                                        <span class="badge ok">@e.Grade</span>
                                    }
                                    else
                                    {
                                        <span class="badge warn">In progress</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
