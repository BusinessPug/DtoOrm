@{
    var nav = new (string Page, string Label)[]
    {
        ("/Index", "Dashboard"),
        ("/Students/Index", "Students"),
        ("/Offerings/Index", "Offerings"),
    };
    string? current = ViewContext.RouteData.Values["page"] as string;
    bool IsActive(string page) =>
        current is not null &&
        (current.Equals(page, StringComparison.OrdinalIgnoreCase) ||
         (page.EndsWith("/Index", StringComparison.OrdinalIgnoreCase) &&
          current.StartsWith(page[..^"/Index".Length] + "/", StringComparison.OrdinalIgnoreCase)));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · DtoOrm School Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a class="brand" asp-page="/Index">
                <span class="brand-mark">◆</span>
                <span>DtoOrm School</span>
            </a>
            <nav class="nav">
                @foreach (var item in nav)
                {
                    <a asp-page="@item.Page" class="nav-link @(IsActive(item.Page) ? "active" : null)">@item.Label</a>
                }
            </nav>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container footer-inner">
            <div>
                <a class="brand footer-brand" asp-page="/Index">
                    <span class="brand-mark">◆</span>
                    <span>DtoOrm School</span>
                </a>
                <p class="footer-tag">A little sample portal showing off typed SQL from the DtoOrm School API — joins, groupings and reports, served warm.</p>
            </div>
            <div class="footer-meta">
                <span class="footer-chip">Razor Pages</span>
                <span class="footer-chip">Minimal API</span>
                <span class="footer-chip">MariaDB</span>
                <span class="footer-note">Made with care · @DateTime.Now.Year</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
