@page
@model DtoOrm.Portal.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-shell">
    <section class="auth-panel">
        <div class="eyebrow">School portal</div>
        <h1>Sign in</h1>
        <p>Use one of the seeded school accounts to see the portal adapt to an administrator, teacher, or student.</p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert">@Model.ErrorMessage</div>
        }

        <form method="post" class="login-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="field">
                <label asp-for="Username">Username or email</label>
                <input asp-for="Username" autocomplete="username" autofocus />
                <span asp-validation-for="Username"></span>
            </div>
            <div class="field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" autocomplete="current-password" />
                <span asp-validation-for="Password"></span>
            </div>
            <button class="btn" type="submit">Sign in</button>
        </form>
    </section>

    <aside class="demo-users">
        <h2>Seeded accounts</h2>
        <div class="demo-user">
            <strong>admin</strong>
            <span>Administrator</span>
        </div>
        <div class="demo-user">
            <strong>teacher.ada</strong>
            <span>Teacher linked to Ada Lovelace</span>
        </div>
        <div class="demo-user">
            <strong>student.liam</strong>
            <span>Student linked to Liam Andersen</span>
        </div>
        <p class="muted-note">Password for all demo accounts: <code>School123!</code></p>
    </aside>
</div>
